---
import type { MenuItem } from '../data/menu';

interface Props {
  item: MenuItem;
}

const { item } = Astro.props;
---

<article class="menu-card reveal">
  <div class="menu-card-header">
    <h3 class="menu-card-name">
      <span class="name-line1">{item.nameLine1}</span>
      <span class="name-line2">{item.nameLine2}</span>
    </h3>
    {item.spicy && (
      <span class="menu-card-spicy" title="Obsahuje jalapeños">
        <img src="/elements/chilli-papricka.png" alt="pikantní" width="18" height="27" loading="lazy" />
      </span>
    )}
  </div>
  <p class="menu-card-desc">{item.description}</p>
</article>

<style>
  .menu-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(0, 180, 180, 0.25);
    border-radius: var(--border-radius-card);
    padding: 1.6rem 1.5rem 1.8rem;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .menu-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 180, 180, 0.06) 0%, transparent 55%);
    pointer-events: none;
  }

  .menu-card:hover {
    border-color: var(--color-pink);
    box-shadow: 0 0 30px rgba(255, 45, 126, 0.18), 0 4px 20px rgba(0,0,0,0.3);
    transform: translateY(-4px);
  }

  .menu-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .menu-card-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-cream);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .name-line1,
  .name-line2 {
    display: block;
  }

  .menu-card-spicy {
    flex-shrink: 0;
    margin-top: 2px;
    display: flex;
    align-items: center;
  }

  .menu-card-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-teal);
    font-weight: 700;
    margin-bottom: 0.7rem;
    font-style: italic;
    line-height: 1.3;
  }

  .menu-card-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(245, 240, 220, 0.7);
    line-height: 1.6;
    margin-top: auto;
  }
</style>
