---

<section id="kontakt" class="contact-section">
  <div class="contact-bg-decos" aria-hidden="true">
    <img src="/elements/calavera.png" alt="" class="contact-calavera contact-calavera-1" width="160" height="185" loading="lazy" />
    <img src="/elements/calavera.png" alt="" class="contact-calavera contact-calavera-2" width="110" height="127" loading="lazy" />
    <img src="/elements/plameny.png"  alt="" class="contact-plameny" width="180" height="190" loading="lazy" />
  </div>

  <div class="container contact-inner">
    <div class="contact-content reveal">
      <p class="contact-label">Catering & soukromé akce</p>
      <h2 class="contact-heading">Rozbalíme gastro&nbsp;show<br />i&nbsp;na&nbsp;vaší&nbsp;akci!</h2>
      <p class="contact-sub">
        Máte akci? My máme tortilly, omáčky a tým, který se nezalekne ani hladového davu.
        Vy slavíte. My přijedeme, rozbalíme maringotku a nakrmíme všechny od strejdy po účetní.
      </p>

      <div class="contact-open-sign" aria-hidden="true">
        <img src="/elements/cedule-open.png" alt="" width="120" height="120" loading="lazy" />
      </div>

      <div class="contact-buttons">
        <a href="tel:+420608584060" class="btn btn-pink contact-btn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.64 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.55 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          +420 608 58 40 60
        </a>
        <a href="mailto:foodtruck@udvoupratel.fun" class="btn btn-teal contact-btn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          foodtruck@udvoupratel.fun
        </a>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    <!-- Dekorativní prvky ve footeru -->
    <div class="footer-decos" aria-hidden="true">
      <img src="/elements/calavera.png"      alt="" class="footer-deco footer-deco-l"  width="140" height="162" loading="lazy" />
      <img src="/elements/kaktus.png"        alt="" class="footer-deco footer-deco-r"  width="100" height="122" loading="lazy" />
      <img src="/elements/chilli-papricka.png" alt="" class="footer-deco footer-deco-chilli" width="50" height="75" loading="lazy" />
    </div>

    <div class="container footer-body">

      <img src="/logo.png" alt="U Dvou Přátel" class="footer-logo" width="280" height="280" loading="lazy" />

      <p class="footer-motto">
        U Dvou přátel&thinsp;—&thinsp;protože nejlepší věci
        vznikají z&nbsp;hladu, nápadu a&nbsp;dobrého kámoše po&nbsp;ruce.
      </p>

      <div class="footer-contact">
        <a href="tel:+420608584060" class="footer-contact-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.64 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.55 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          +420 608 58 40 60
        </a>
        <a href="mailto:foodtruck@udvoupratel.fun" class="footer-contact-link">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          foodtruck@udvoupratel.fun
        </a>
      </div>

    </div>

    <!-- Spodní lišta -->
    <div class="footer-bar">
      <div class="container footer-bar-inner">
        <p class="footer-copy">© 2025 U&nbsp;Dvou Přátel – Food Truck Gastro Show</p>
        <p class="footer-social-soon">Instagram &amp; Facebook — brzy</p>
      </div>
    </div>
  </footer>
</section>

<style>
  .contact-section {
    position: relative;
    background: linear-gradient(180deg, var(--color-dark) 0%, #0d0618 100%);
    overflow: hidden;
  }

  /* Dekorativní pozadí */
  .contact-bg-decos {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .contact-calavera {
    position: absolute;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.5));
  }

  .contact-calavera-1 {
    top: 8%;
    left: 4%;
    opacity: 0.18;
  }

  .contact-calavera-2 {
    bottom: 18%;
    right: 5%;
    opacity: 0.12;
    transform: scaleX(-1);
  }

  .contact-plameny {
    position: absolute;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.07;
    pointer-events: none;
    filter: blur(2px);
  }

  .contact-inner {
    padding: 6rem 0;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .contact-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
    margin-bottom: 0.8rem;
  }

  .contact-heading {
    font-size: clamp(2.6rem, 5vw, 4.5rem);
    line-height: 1.3;
    margin-bottom: 1.4rem;
  }

  .contact-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(245, 240, 220, 0.65);
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  /* OPEN cedule */
  .contact-open-sign {
    margin: 0 auto 2rem;
    display: inline-block;
    animation: float-slow 5s ease-in-out infinite;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,0.5));
  }

  .contact-open-sign img { display: block; }

  .contact-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .contact-btn {
    font-size: 1.1rem;
    padding: 1rem 2rem;
  }

  /* ── FOOTER ───────────────────────────────────────── */
  .site-footer {
    position: relative;
    background: #08021a;
    border-top: 1px solid rgba(0, 180, 180, 0.12);
    overflow: hidden;
    z-index: 1;
  }

  /* Dekorativní prvky */
  .footer-decos { pointer-events: none; }

  .footer-deco {
    position: absolute;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
  }

  .footer-deco-l {
    left: 2%;
    bottom: 24px;
    opacity: 0.12;
    filter: saturate(0.4) brightness(0.8);
  }

  .footer-deco-r {
    right: 2%;
    bottom: 20px;
    opacity: 0.14;
    filter: saturate(0.4) brightness(0.8);
  }

  .footer-deco-chilli {
    right: 12%;
    top: 28px;
    opacity: 0.1;
    transform: rotate(-20deg);
    filter: saturate(0.3);
  }

  /* Body – centrovaný sloupcový layout */
  .footer-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
    padding: 4rem 0 3rem;
    position: relative;
    z-index: 1;
  }

  .footer-logo {
    width: 240px;
    height: 240px;
    object-fit: contain;
    opacity: 0.5;
    filter: drop-shadow(0 4px 24px rgba(0, 180, 180, 0.2));
  }

  .footer-motto {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(245, 240, 220, 0.55);
    line-height: 1.7;
    max-width: 420px;
    font-style: italic;
  }

  /* Nav + contact columns */
  .footer-col-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-orange);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-nav a {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(245, 240, 220, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover { color: var(--color-teal); }

  /* Contact links */
  .footer-contact {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: center;
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(245, 240, 220, 0.55);
    text-decoration: none;
    padding: 0.45rem 0;
    transition: color 0.2s;
  }

  .footer-contact-link:hover { color: var(--color-teal); }
  .footer-contact-link svg { flex-shrink: 0; opacity: 0.6; }

  /* Bottom bar */
  .footer-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    z-index: 1;
  }

  .footer-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 0;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(245, 240, 220, 0.22);
  }

  .footer-social-soon {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(245, 240, 220, 0.22);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 860px) {
    .footer-logo { width: 180px; height: 180px; }
  }

  @media (max-width: 560px) {
    .footer-body { grid-template-columns: 1fr; }
    .footer-brand { flex-direction: column; }
    .footer-bar-inner { flex-direction: column; text-align: center; gap: 0.4rem; }
    .footer-deco-l, .footer-deco-r, .footer-deco-chilli { display: none; }
    .contact-btn { width: 100%; justify-content: center; }
    .contact-calavera-1 { opacity: 0.1; width: 100px; }
    .contact-calavera-2 { display: none; }
  }
</style>
